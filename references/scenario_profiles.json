{
  "schema_version": "easyslides.scenario_profiles.v1",
  "rule_levels": {
    "hard_rules": "Always enforce. These protect truthfulness, traceability, text fit, and deliverability.",
    "required_rules": "Enforce for this scenario unless the user explicitly changes the scenario.",
    "recommended_rules": "Default guidance. Apply when it improves clarity, but let templates and scenario needs override it.",
    "relaxable_rules": "Helpful defaults that may be softened when a template, venue, or activity format needs a different shape."
  },
  "hard_rules": [
    {
      "id": "faithful_to_source",
      "rule": "Do not invent paper conclusions, data, methods, citations, or claims.",
      "rationale": "Academic slides must preserve the source argument."
    },
    {
      "id": "source_traceability",
      "rule": "Track where each borrowed figure, table, data point, and key claim came from.",
      "rationale": "Slides need recoverable evidence, not just polished prose."
    },
    {
      "id": "citation_retention",
      "rule": "Keep citations or source notes visible when borrowed material appears on a slide.",
      "rationale": "Academic integrity rules override template aesthetics."
    },
    {
      "id": "text_fit",
      "rule": "No generated text may overflow or become unreadable inside the selected layout.",
      "rationale": "A beautiful template fails if content does not fit."
    },
    {
      "id": "template_geometry_integrity",
      "rule": "For mirror and slot-guided templates, preserve fixed geometry unless the template contract allows editing.",
      "rationale": "Templates are content containers with their own spatial contract."
    },
    {
      "id": "pptx_deliverability",
      "rule": "The final PPTX must open and remain editable according to the chosen EasySlides backend.",
      "rationale": "The user needs a usable deliverable, not only intermediate assets."
    }
  ],
  "template_override_policy": {
    "principle": "Templates control visual containers; scenario profiles control content organization; hard rules preserve trust and delivery.",
    "template_may_override": [
      "palette",
      "title_treatment",
      "divider_style",
      "icon_usage",
      "background_treatment",
      "page_chrome",
      "layout_density"
    ],
    "template_must_not_override": [
      "faithful_to_source",
      "source_traceability",
      "citation_retention",
      "text_fit",
      "template_geometry_integrity",
      "pptx_deliverability"
    ]
  },
