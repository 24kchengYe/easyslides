{
  "schema_version": "easyslides.l001_layouts.v1",
  "style_system": "l001_notebook_defense",
  "layouts": [
    {
      "id": "01_cover",
      "page_type": "cover",
      "template": "01_cover.svg",
      "source_layout": "L001-S01",
      "slots": ["TITLE", "SUBTITLE", "META", "BRAND", "RESPONDENT", "ADVISOR", "DATE"],
      "required_tokens": ["burgundy_band", "pale_dot", "cover_title", "cover_subtitle", "closing_meta"],
      "layout_contract": "cover_band_px"
    },
    {
      "id": "02_toc",
      "page_type": "toc",
      "template": "02_toc.svg",
      "source_layout": "L001-S02",
      "layout_contract": "toc_band_px",
      "slots": ["TOC_TITLE", "TOC_SUBTITLE", "ITEM_1", "ITEM_2", "ITEM_3", "ITEM_4", "ITEM_5"],
      "required_tokens": ["burgundy_band", "toc_title", "toc_item_number", "toc_item_title"]
    },
    {
      "id": "03_section",
      "page_type": "section",
      "template": "03_section.svg",
      "source_layout": "L001-S03/S07/S12/S17/S22",
      "layout_contract": "section_band_px",
      "slots": ["SECTION_NUMBER", "PART_LABEL", "SECTION_TITLE", "SECTION_SUBTITLE"],
      "required_tokens": ["burgundy_band", "section_number", "section_part_label", "section_title"]
    },
    {
      "id": "04_content",
      "page_type": "content",
      "template": "04_content.svg",
      "source_layout": "L001 content family",
      "slots": ["ACTIVE_SECTION", "PAGE_TITLE", "CARD_TITLE", "BODY", "NAV_ITEM_1", "NAV_ITEM_2", "NAV_ITEM_3", "NAV_ITEM_4", "NO", "BRAND"],
      "required_tokens": ["left_nav_surface", "burgundy_band", "paper_card", "content_title", "body", "nav_item"]
    },
    {
      "id": "05_closing",
      "page_type": "closing",
      "template": "05_closing.svg",
      "source_layout": "L001-S27",
      "layout_contract": "closing_band_px",
      "slots": ["CLOSING_TITLE", "RESPONDENT", "ADVISOR", "DATE"],
      "required_tokens": ["burgundy_band", "closing_title", "closing_meta", "pale_dot"]
    }
  ]
}
